# ── Python bytecode & tooling ──────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.mypy_cache/
.ruff_cache/
.streamlit/

# ── Runtime / memory data boundary ─────────────────────────────────────────
# These files are mutable operational state — never tracked in git.
# Live under runtime/, data/, or the repo root during local dev.
dad_memory.json
dad_memory.json.bak
dad_profile.json
dad_profile.json.bak
*.sqlite3
*.sqlite3-shm
*.sqlite3-wal

# Runtime directory (created to hold mutable state in production)
runtime/
data/
memory/

# Session logs (ephemeral turn records)
session_logs/

# Export / import artefacts
memory_export*.json

# Diagnostic / process logs
_dad_stop_stdout.txt
_dad_stop_stderr.txt
dad_run_stdout.log
dad_run_stderr.log
*.log

# Temp pytest helpers generated at runtime
_tmp_pytest_*.py
.pytest_slice_output.txt
.unittest_regression_verbose.log

# Secrets / env
.env
.env.*
!.env.example
!.env.production.example

# OS / editor
.DS_Store
Thumbs.db
.vscode/settings.json

