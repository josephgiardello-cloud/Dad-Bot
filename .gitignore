/runtime/
data/
/memory/

# Session logs (ephemeral turn records)
session_logs/

# Export / import artefacts
memory_export*.json

# Memory forgetting snapshots (belt-and-suspenders for repo-root stragglers)
memory_forgetting_backup_*.json

# System snapshots / runtime backups (canonical home: artifacts/backups/)
