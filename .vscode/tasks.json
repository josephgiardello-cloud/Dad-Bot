{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Test Lane: DEV",
			"type": "shell",
			"command": "${workspaceFolder}/.venv/Scripts/python.exe",
			"args": [
				"-m",
				"pytest",
				"-m",
				"unit",
				"--durations=15",
				"-q"
			],
			"group": "test"
		},
		{
			"label": "Test Lane: INTEGRATION",
			"type": "shell",
			"command": "${workspaceFolder}/.venv/Scripts/python.exe",
			"args": [
				"-m",
				"pytest",
				"-m",
				"integration",
				"-q"
			],
			"group": "test"
		},
		{
			"label": "Test Lane: DURABILITY / PHASE4",
			"type": "shell",
			"command": "${workspaceFolder}/.venv/Scripts/python.exe",
			"args": [
				"-m",
				"pytest",
				"-m",
				"durability or phase4",
				"--durations=15",
				"-q"
			],
			"group": "test"
		},
		{
			"label": "Test Lane: SOAK",
			"type": "shell",
			"command": "${workspaceFolder}/.venv/Scripts/python.exe",
			"args": [
				"-m",
				"pytest",
				"-m",
				"soak",
				"-q"
			],
			"group": "test"
		},
		{
			"label": "Test Lane: DETERMINISM STRESS",
			"type": "shell",
			"command": "${workspaceFolder}/.venv/Scripts/python.exe",
			"args": [
				"-m",
				"pytest",
				"--run-stress",
				"-m",
				"stress",
				"--durations=20",
				"-q"
			],
			"group": "test"
		},
		{
			"label": "Test Lane: UI",
			"type": "shell",
			"command": "${workspaceFolder}/.venv/Scripts/python.exe",
			"args": [
				"-m",
				"pytest",
				"-m",
				"ui",
				"-q"
			],
			"group": "test"
		},
		{
			"label": "Test Lane: CERT / REGRESSION",
			"type": "shell",
			"command": "${workspaceFolder}/.venv/Scripts/python.exe",
			"args": [
				"tools/cert_baseline_capture.py",
				"--durations",
				"20",
				"--write-baseline",
				"--report-markdown"
			],
			"group": "test"
		},
		{
			"label": "Test Lane: FULL CERT",
			"type": "shell",
			"command": "${workspaceFolder}/.venv/Scripts/python.exe",
			"args": [
				"-m",
				"pytest",
				"-q"
			],
			"group": "test"
		},
		{
			"label": "Run Dad Bot",
			"type": "shell",
			"command": "${workspaceFolder}/.venv/Scripts/python.exe",
			"args": [
				"Dad.py",
				"--model",
				"llama3.2:latest"
			],
			"options": {
				"env": {
					"DADBOT_LLM_MODEL": "llama3.2:latest"
				}
			},
			"isBackground": true,
			"group": "build"
		},
		{
			"label": "Run Dad Bot MCP Server",
			"type": "shell",
			"command": "${workspaceFolder}/.venv/Scripts/python.exe -m dadbot_system.local_mcp_server *> session_logs/local_mcp_server.task.log",
			"isBackground": true,
			"group": "build"
		},
		{
			"label": "Run Sovereign Heartbeat Daemon",
			"type": "shell",
			"command": "${workspaceFolder}/.venv/Scripts/python.exe",
			"args": [
				"Dad.py",
				"heartbeat-daemon",
				"--interval-seconds",
				"60",
				"--consolidation-interval-seconds",
				"300"
			],
			"isBackground": true,
			"group": "build"
		},
		{
			"label": "Run HUD Watch",
			"type": "shell",
			"command": "${workspaceFolder}/.venv/Scripts/python.exe",
			"args": [
				"Dad.py",
				"hud",
				"--interval-seconds",
				"2"
			],
			"isBackground": true,
			"group": "build"
		},
		{
			"label": "Contract Gate: STRICT",
			"type": "shell",
			"command": "${workspaceFolder}/.venv/Scripts/python.exe",
			"args": [
				"_ci_gate_check.py",
				"--contract-gate"
			],
			"group": "test"
		},
		{
			"label": "Inspect: System Health",
			"type": "shell",
			"command": "${workspaceFolder}/.venv/Scripts/python.exe",
			"args": [
				"tools/inspect_system.py",
				"--health"
			],
			"problemMatcher": [],
			"group": "test"
		},
		{
			"label": "Inspect: Tool Capabilities",
			"type": "shell",
			"command": "${workspaceFolder}/.venv/Scripts/python.exe",
			"args": [
				"tools/inspect_system.py",
				"--tools"
			],
			"problemMatcher": [],
			"group": "test"
		},
		{
			"label": "Inspect: Last Scale Report",
			"type": "shell",
			"command": "${workspaceFolder}/.venv/Scripts/python.exe",
			"args": [
				"tools/inspect_system.py",
				"--last-report"
			],
			"problemMatcher": [],
			"group": "test"
		},
		{
			"label": "Inspect: Invariant Violations",
			"type": "shell",
			"command": "${workspaceFolder}/.venv/Scripts/python.exe",
			"args": [
				"tools/inspect_system.py",
				"--violations"
			],
			"problemMatcher": [],
			"group": "test"
		},
		{
			"label": "System: Scale Validation (10k)",
			"type": "shell",
			"command": "${workspaceFolder}/.venv/Scripts/python.exe",
			"args": [
				"tools/system_validation_at_scale.py",
				"--turns",
				"10000"
			],
			"problemMatcher": [],
			"group": "test"
		},
		{
			"label": "System: Scale Validation + Recovery",
			"type": "shell",
			"command": "${workspaceFolder}/.venv/Scripts/python.exe",
			"args": [
				"tools/system_validation_at_scale.py",
				"--turns",
				"1000",
				"--include-unstable-recovery"
			],
			"problemMatcher": [],
			"group": "test"
		},
		{
			"label": "Git status tasks file",
			"type": "shell",
			"command": "git",
			"args": [
				"status",
				"--short",
				".vscode/tasks.json"
			],
			"isBackground": false
		},
		{
			"label": "Stage tasks reconciliation",
			"type": "shell",
			"command": "git",
			"args": [
				"add",
				".vscode/tasks.json"
			],
			"isBackground": false
		},
		{
			"label": "Commit tasks reconciliation",
			"type": "shell",
			"command": "git",
			"args": [
				"commit",
				"-m",
				"Reconcile tasks with baseline: mark scanner convergence fix complete",
				".vscode/tasks.json"
			],
			"isBackground": false
		}
	]
}
