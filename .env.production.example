DADBOT_API_URL=http://127.0.0.1:8010
DADBOT_API_HOST=0.0.0.0
DADBOT_API_PORT=8010
DADBOT_API_VERSION_PREFIX=/v1
DADBOT_API_WORKERS=2
DADBOT_API_TOKEN_SECRET=replace-with-strong-random-secret
DADBOT_API_TOKEN_ISSUER=dadbot
DADBOT_API_AUTH_REQUIRED=true
DADBOT_API_RATE_LIMIT_PER_MINUTE=120
DADBOT_API_WRITE_RATE_LIMIT_PER_MINUTE=60
DADBOT_API_ADMIN_RATE_LIMIT_PER_MINUTE=20
DADBOT_DEFAULT_MODEL=llama3.2

# Durable state backends
DADBOT_REDIS_URL=redis://redis:6379/0
DADBOT_POSTGRES_DSN=postgresql://dadbot:dadbot@postgres:5432/dadbot

# PGVector semantic search
DADBOT_SEMANTIC_INDEX_TABLE=semantic_memories
# Set this to your embedding dimension to enable ANN indexing.
# Examples: bge-m3=1024, nomic-embed-text=768.
# DADBOT_SEMANTIC_VECTOR_DIM=1024
# DADBOT_SEMANTIC_ANN_INDEX=hnsw
DADBOT_SEMANTIC_DISTANCE_METRIC=cosine
DADBOT_SEMANTIC_HNSW_M=16
DADBOT_SEMANTIC_HNSW_EF_CONSTRUCTION=64
DADBOT_SEMANTIC_IVFFLAT_LISTS=100

# Runtime file locations inside the container volume
DADBOT_PROFILE_PATH=/var/lib/dadbot/dad_profile.json
DADBOT_MEMORY_PATH=/var/lib/dadbot/dad_memory.json
DADBOT_SEMANTIC_DB_PATH=/var/lib/dadbot/dad_memory_semantic.sqlite3
DADBOT_SESSION_LOG_DIR=/var/log/dadbot/session_logs
DADBOT_EVENT_ENCRYPTION_KEY=replace-with-separate-durability-key
DADBOT_AUTO_INIT_PROFILE=true

# Telemetry
DADBOT_LOG_LEVEL=INFO
DADBOT_JSON_LOGS=true
DADBOT_OTEL_ENABLED=false
DADBOT_SERVICE_NAME=dadbot